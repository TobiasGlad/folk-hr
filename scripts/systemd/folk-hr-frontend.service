[Unit]
Description=Folk HR frontend dev server
After=network.target folk-hr-backend.service
Wants=folk-hr-backend.service

[Service]
Type=simple
WorkingDirectory=/srv/web-projects/folk-hr
Environment=PATH=/home/tobias/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/tobias/.local/bin/npm run dev -- --host 0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
